@model LaboratoryHeadApp.Models.ClassroomReservationCreateViewModel

@{
    var isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Редактирование брони" : "Бронирование аудитории";
    Layout = "_Layout";

    var classroomManual = !Model.SelectedClassroomId.HasValue && !string.IsNullOrWhiteSpace(Model.ClassroomNumber);
    var teacherManual = !Model.SelectedTeacherId.HasValue && !string.IsNullOrWhiteSpace(Model.TeacherName);
    var groupManual = !Model.SelectedGroupId.HasValue && !string.IsNullOrWhiteSpace(Model.GroupName);
}

<style>
    :root {
        --galaxy: #0B1F5C;
        --planetary: #334EAC;
        --sky: #D0E3FF;
        --ink: #0f172a;
        --line: rgba(11, 31, 92, .18);
        --card: #ffffff;
        --soft: #f6f8ff;
        --cell: #fbfcff;
    }

    .page-title {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }

    .btn-galaxy {
        background-color: var(--galaxy);
        border: 1px solid var(--galaxy);
        color: #fff;
        border-radius: 10px;
        height: 38px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        transition: .15s;
        text-decoration: none;
    }

        .btn-galaxy:hover {
            background-color: var(--planetary);
            border-color: var(--planetary);
            color: #fff;
        }

    .btn-outline-galaxy {
        color: var(--galaxy);
        border: 1px solid var(--galaxy);
        background: #fff;
        border-radius: 10px;
        height: 38px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        transition: .15s;
        text-decoration: none;
    }

        .btn-outline-galaxy:hover {
            background: var(--galaxy);
            color: #fff;
        }

    .grid-wrap {
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 16px;
        background: #fff;
        box-shadow: 0 1px 2px rgba(0,0,0,.04);
        overflow: visible;
    }

    .form-section + .form-section {
        margin-top: 18px;
    }

    .section-title {
        font-size: 16px;
        font-weight: 800;
        color: var(--galaxy);
        margin-bottom: 4px;
    }

    .section-hint {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 14px;
    }

    .grid-2 {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .field-block label:not(.manual-switch) {
        display: block;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 6px;
        font-size: 14px;
    }

    .form-control,
    .form-select {
        border-radius: 10px;
        border: 1px solid var(--line);
        min-height: 40px;
        box-shadow: none !important;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--planetary);
        }

    .manual-switch {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 10px;
        font-size: 13px;
        color: var(--galaxy);
        font-weight: 700;
        cursor: pointer;
        user-select: none;
    }

    .manual-box {
        margin-top: 10px;
        padding: 12px;
        border: 1px dashed rgba(11, 31, 92, .18);
        border-radius: 12px;
        background: var(--soft);
    }

    .manual-tip {
        margin-top: 6px;
        font-size: 12px;
        color: #64748b;
        line-height: 1.3;
    }

    .time-note {
        margin-top: 10px;
        font-size: 12px;
        color: #64748b;
    }

    .validation-box {
        border: 1px solid #f5c2c7;
        background: #fff5f5;
        color: #842029;
        border-radius: 12px;
        padding: 12px 14px;
        margin-bottom: 12px;
    }

    .text-danger.small {
        display: block;
        margin-top: 5px;
        font-size: 12px;
    }

    .actions-bar {
        display: flex;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
    }

    @@media (max-width: 992px) {
        .grid-3 {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .grid-2 {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container py-4">
    <div class="page-title">
        <div>
            <h2 class="mb-1">@ViewData["Title"]</h2>
            <div class="text-muted" style="font-size: 14px;">
                @(isEdit
                    ? "Измените данные брони и сохраните изменения."
                    : "Заполните данные для бронирования аудитории.")
            </div>
        </div>

        <a asp-controller="Schedule"
           asp-action="LessonsRooms"
           asp-route-date="@Model.Date.ToString("yyyy-MM-dd")"
           class="btn btn-outline-galaxy">
            Назад к расписанию
        </a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="validation-box"></div>
    }

    <div class="grid-wrap">
        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />
            <input asp-for="ClassroomId" type="hidden" />
            <input asp-for="TeacherId" type="hidden" />
            <input asp-for="GroupId" type="hidden" />

            <div class="form-section">
                <div class="section-title">Когда</div>
                <div class="section-hint">Выберите дату и либо пару, либо время вручную.</div>

                <div class="grid-2">
                    <div class="field-block">
                        <label asp-for="Date"></label>
                        <input asp-for="Date" type="date" class="form-control" />
                        <span asp-validation-for="Date" class="text-danger small"></span>
                    </div>

                    <div class="field-block">
                        <label asp-for="LessonTimeId">Выберите пару</label>
                        <select asp-for="LessonTimeId"
                                asp-items="Model.LessonTimes"
                                class="form-select"
                                id="lessonTimeSelect">
                            <option value="">Выберите пару</option>
                        </select>
                        <span asp-validation-for="LessonTimeId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="grid-2 mt-3">
                    <div class="field-block">
                        <label asp-for="StartTime"></label>
                        <input asp-for="StartTime"
                               type="time"
                               class="form-control"
                               id="startTimeInput" />
                        <span asp-validation-for="StartTime" class="text-danger small"></span>
                    </div>

                    <div class="field-block">
                        <label asp-for="EndTime"></label>
                        <input asp-for="EndTime"
                               type="time"
                               class="form-control"
                               id="endTimeInput" />
                        <span asp-validation-for="EndTime" class="text-danger small"></span>
                    </div>
                </div>

                <div class="time-note">
                    Если выбрана пара, время вручную заполнять не нужно. Если пары нет — укажите время начала и окончания.
                </div>
            </div>

            <div class="form-section">
                <div class="section-title">Где и для кого</div>
                <div class="section-hint">Для аудитории, преподавателя и группы можно выбрать значение из списка или ввести его вручную.</div>

                <div class="grid-3">
                    <div class="field-block">
                        <label asp-for="SelectedClassroomId">Аудитория</label>

                        <div id="classroomSelectWrap">
                            <select asp-for="SelectedClassroomId"
                                    asp-items="Model.Classrooms"
                                    class="form-select"
                                    id="classroomSelect">
                                <option value="">Выберите аудиторию</option>
                            </select>
                        </div>

                        <label class="manual-switch" for="classroomManualToggle">
                            <input type="checkbox" id="classroomManualToggle" />
                            <span>Нет в списке? Ввести вручную</span>
                        </label>

                        <div id="classroomInputWrap" class="manual-box d-none">
                            <label asp-for="ClassroomNumber"></label>
                            <input asp-for="ClassroomNumber"
                                   class="form-control"
                                   id="classroomInput"
                                   placeholder="Например, 302" />
                            <span asp-validation-for="ClassroomNumber" class="text-danger small"></span>
                            <div class="manual-tip">
                                Заполняйте это поле только если аудитории нет в выпадающем списке.
                            </div>
                        </div>
                    </div>

                    <div class="field-block">
                        <label asp-for="SelectedTeacherId">Преподаватель</label>

                        <div id="teacherSelectWrap">
                            <select asp-for="SelectedTeacherId"
                                    asp-items="Model.Teachers"
                                    class="form-select"
                                    id="teacherSelect">
                                <option value="">Выберите преподавателя</option>
                            </select>
                        </div>

                        <label class="manual-switch" for="teacherManualToggle">
                            <input type="checkbox" id="teacherManualToggle" />
                            <span>Нет в списке? Ввести вручную</span>
                        </label>

                        <div id="teacherInputWrap" class="manual-box d-none">
                            <label asp-for="TeacherName"></label>
                            <input asp-for="TeacherName"
                                   class="form-control"
                                   id="teacherInput"
                                   placeholder="ФИО преподавателя" />
                            <span asp-validation-for="TeacherName" class="text-danger small"></span>
                            <div class="manual-tip">
                                Заполняйте это поле только если преподавателя нет в выпадающем списке.
                            </div>
                        </div>
                    </div>

                    <div class="field-block">
                        <label asp-for="SelectedGroupId">Группа</label>

                        <div id="groupSelectWrap">
                            <select asp-for="SelectedGroupId"
                                    asp-items="Model.Groups"
                                    class="form-select"
                                    id="groupSelect">
                                <option value="">Выберите группу</option>
                            </select>
                        </div>

                        <label class="manual-switch" for="groupManualToggle">
                            <input type="checkbox" id="groupManualToggle" />
                            <span>Нет в списке? Ввести вручную</span>
                        </label>

                        <div id="groupInputWrap" class="manual-box d-none">
                            <label asp-for="GroupName"></label>
                            <input asp-for="GroupName"
                                   class="form-control"
                                   id="groupInput"
                                   placeholder="Например, ИВТ-31" />
                            <span asp-validation-for="GroupName" class="text-danger small"></span>
                            <div class="manual-tip">
                                Заполняйте это поле только если группы нет в выпадающем списке.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="section-title">Что проводится</div>
                <div class="section-hint">Укажите тему брони и при необходимости добавьте комментарий.</div>

                <div class="grid-2">
                    <div class="field-block">
                        <label asp-for="Subject"></label>
                        <input asp-for="Subject"
                               class="form-control"
                               placeholder="Например, консультация по ВКР" />
                        <span asp-validation-for="Subject" class="text-danger small"></span>
                    </div>

                    <div class="field-block">
                        <label asp-for="Comment"></label>
                        <input asp-for="Comment"
                               class="form-control"
                               placeholder="Необязательно" />
                        <span asp-validation-for="Comment" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="actions-bar">
                <a asp-controller="Schedule"
                   asp-action="LessonsRooms"
                   asp-route-date="@Model.Date.ToString("yyyy-MM-dd")"
                   class="btn btn-outline-secondary">
                    Отмена
                </a>

                <button type="submit" class="btn btn-galaxy">
                    @(isEdit ? "Сохранить изменения" : "Забронировать")
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function setupManualBlock(options) {
                const toggle = document.getElementById(options.toggleId);
                const selectWrap = document.getElementById(options.selectWrapId);
                const inputWrap = document.getElementById(options.inputWrapId);
                const select = document.getElementById(options.selectId);
                const input = document.getElementById(options.inputId);
                const entityId = document.getElementById(options.entityIdId);

                function applyMode(manual) {
                    toggle.checked = manual;

                    selectWrap.classList.toggle("d-none", manual);
                    inputWrap.classList.toggle("d-none", !manual);

                    select.disabled = manual;
                    input.disabled = !manual;

                    if (manual) {
                        select.value = "";
                        if (entityId) entityId.value = "";
                    } else {
                        input.value = "";
                        if (entityId) entityId.value = "";
                    }
                }

                toggle.addEventListener("change", function () {
                    applyMode(toggle.checked);
                });

                applyMode(options.initialManual);
            }

            setupManualBlock({
                toggleId: "classroomManualToggle",
                selectWrapId: "classroomSelectWrap",
                inputWrapId: "classroomInputWrap",
                selectId: "classroomSelect",
                inputId: "classroomInput",
                entityIdId: "ClassroomId",
                initialManual: @classroomManual.ToString().ToLower()
                    });

            setupManualBlock({
                toggleId: "teacherManualToggle",
                selectWrapId: "teacherSelectWrap",
                inputWrapId: "teacherInputWrap",
                selectId: "teacherSelect",
                inputId: "teacherInput",
                entityIdId: "TeacherId",
                initialManual: @teacherManual.ToString().ToLower()
                    });

            setupManualBlock({
                toggleId: "groupManualToggle",
                selectWrapId: "groupSelectWrap",
                inputWrapId: "groupInputWrap",
                selectId: "groupSelect",
                inputId: "groupInput",
                entityIdId: "GroupId",
                initialManual: @groupManual.ToString().ToLower()
                    });

            const lessonTimeSelect = document.getElementById("lessonTimeSelect");
            const startTimeInput = document.getElementById("startTimeInput");
            const endTimeInput = document.getElementById("endTimeInput");

            function syncTimeMode() {
                const hasLessonTime = lessonTimeSelect.value !== "";
                const hasManualTime = startTimeInput.value !== "" || endTimeInput.value !== "";

                if (hasLessonTime) {
                    startTimeInput.disabled = true;
                    endTimeInput.disabled = true;
                } else {
                    startTimeInput.disabled = false;
                    endTimeInput.disabled = false;
                }

                if (hasManualTime && !hasLessonTime) {
                    lessonTimeSelect.disabled = true;
                } else {
                    lessonTimeSelect.disabled = false;
                }
            }

            lessonTimeSelect.addEventListener("change", syncTimeMode);
            startTimeInput.addEventListener("input", syncTimeMode);
            endTimeInput.addEventListener("input", syncTimeMode);

            syncTimeMode();
        });
    </script>
}