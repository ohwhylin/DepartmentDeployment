@model ScheduleServiceContracts.BindingModels.TeacherBindingModel

@{
    ViewData["Title"] = "Редактирование преподавателя";
    Layout = "_Layout";
}

<style>
    :root {
        --galaxy: #0B1F5C;
        --planetary: #334EAC;
        --line: rgba(11, 31, 92, .15);
        --soft: #f8f9fc;
    }

    .page-card {
        max-width: 760px;
        margin: 0 auto;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: #fff;
        box-shadow: 0 8px 22px rgba(11, 31, 92, .06);
        overflow: hidden;
    }

    .page-card-header {
        padding: 18px 22px;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(180deg, #fff, var(--soft));
    }

    .page-card-body {
        padding: 22px;
    }

    .btn-galaxy {
        background-color: var(--galaxy);
        border-color: var(--galaxy);
        color: #fff;
    }

        .btn-galaxy:hover,
        .btn-galaxy:focus {
            background-color: var(--planetary);
            border-color: var(--planetary);
            color: #fff;
        }

    .btn-outline-galaxy {
        color: var(--galaxy);
        border-color: var(--galaxy);
    }

        .btn-outline-galaxy:hover,
        .btn-outline-galaxy:focus {
            background-color: var(--galaxy);
            color: #fff;
        }

    .info-note {
        color: #6c757d;
        font-size: .95rem;
        margin-bottom: 16px;
    }
</style>

<div class="container py-4">
    <div class="page-card">
        <div class="page-card-header">
            <h2 class="mb-1">Редактирование преподавателя</h2>
            <div class="text-muted">Изменение данных преподавателя</div>
        </div>

        <div class="page-card-body">
            <div class="info-note">
                Идентификатор Core System не редактируется.
            </div>

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input asp-for="Id" type="hidden" />
                <input asp-for="CoreSystemId" type="hidden" />

                <div class="mb-4">
                    <label asp-for="TeacherName" class="form-label">Преподаватель</label>
                    <input asp-for="TeacherName" class="form-control" />
                    <span asp-validation-for="TeacherName" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-galaxy">Назад</a>
                    <button type="submit" class="btn btn-galaxy">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>