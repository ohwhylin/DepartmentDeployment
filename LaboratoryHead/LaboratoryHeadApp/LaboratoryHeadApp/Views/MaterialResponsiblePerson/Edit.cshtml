@model MolServiceContracts.BindingModels.MaterialResponsiblePersonBindingModel

@{
    ViewData["Title"] = "Редактирование МОЛ";
    Layout = "_Layout";
}

<style>
    :root {
        --galaxy: #0B1F5C;
        --planetary: #334EAC;
    }

    .btn-galaxy {
        background-color: var(--galaxy);
        border-color: var(--galaxy);
        color: #fff;
    }

        .btn-galaxy:hover,
        .btn-galaxy:focus {
            background-color: var(--planetary);
            border-color: var(--planetary);
            color: #fff;
        }

    .btn-outline-galaxy {
        color: var(--galaxy);
        border-color: var(--galaxy);
    }

        .btn-outline-galaxy:hover,
        .btn-outline-galaxy:focus {
            background-color: var(--galaxy);
            color: #fff;
        }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Редактирование МОЛ</h2>
        <a asp-action="Index" class="btn btn-outline-galaxy">Назад</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" placeholder="Иванов И. И." />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Position" class="form-label"></label>
                    <input asp-for="Position" class="form-control" placeholder="Лаборант" />
                    <span asp-validation-for="Position" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" placeholder="+7 (900) 123-45-67" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="example@domain.ru" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-galaxy">Сохранить</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}