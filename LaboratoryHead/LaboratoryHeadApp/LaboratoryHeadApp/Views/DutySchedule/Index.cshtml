@model LaboratoryHeadApp.Models.DutyScheduleIndexViewModel

@{
    ViewData["Title"] = "График дежурств";
    Layout = "_Layout";

    var dayNames = new[]
    {
        "Понедельник", "Вторник", "Среда", "Четверг", "Пятница", "Суббота", "Воскресенье"
    };

    string GetCellKey(DateTime date, int lessonTimeId)
    {
        return $"{date:yyyy-MM-dd}_{lessonTimeId}";
    }

    List<string> GetCellValues(Dictionary<string, List<string>> data, DateTime date, int lessonTimeId)
    {
        var key = GetCellKey(date, lessonTimeId);

        if (data.TryGetValue(key, out var values) && values.Any())
        {
            return values.Take(2).ToList();
        }

        return new List<string>();
    }
}

<style>
    :root {
        --galaxy: #0B1F5C;
        --planetary: #334EAC;
        --sky: #D0E3FF;
        --line: rgba(11, 31, 92, .18);
        --soft: #f6f8ff;
    }

    .btn-galaxy {
        background: var(--galaxy);
        border-color: var(--galaxy);
        color: #fff;
        border-radius: 10px;
    }

        .btn-galaxy:hover {
            background: var(--planetary);
            border-color: var(--planetary);
            color: #fff;
        }

    .btn-outline-galaxy {
        color: var(--galaxy);
        border-color: var(--galaxy);
        border-radius: 10px;
        background: #fff;
    }

        .btn-outline-galaxy:hover {
            background: var(--galaxy);
            color: #fff;
        }

    .grid-card {
        border: 1px solid var(--line);
        border-radius: 16px;
        background: #fff;
        box-shadow: 0 1px 2px rgba(0,0,0,.04);
    }

    .grid-title {
        font-weight: 800;
        color: var(--galaxy);
        margin: 0;
    }

    .duty-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 6px;
        min-width: 900px;
    }

        .duty-table th,
        .duty-table td {
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 8px 6px;
            background: #fff;
            text-align: center;
            vertical-align: middle;
        }

        .duty-table thead th {
            font-weight: 800;
            color: #0f172a;
            font-size: 14px;
        }

    .pair-time {
        display: block;
        font-weight: 600;
        color: #64748b;
        font-size: 11px;
        margin-top: 3px;
    }

    .day-cell {
        text-align: left !important;
        font-weight: 800;
        color: var(--galaxy);
        background: linear-gradient(0deg, rgba(208,227,255,.45), rgba(208,227,255,.45)), #fff;
        white-space: nowrap;
        min-width: 150px;
    }

    .duty-cell {
        font-weight: 900;
        letter-spacing: .2px;
        font-size: 13px;
        color: #0f172a;
        min-width: 92px;
        height: 70px;
    }

        .duty-cell.empty {
            background: var(--soft);
            color: #94a3b8;
            font-weight: 700;
        }

    .scroll-wrap {
        overflow-x: auto;
        overflow-y: hidden;
        padding: 8px 10px 14px;
    }

    .topbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
    }

    .top-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .date-note {
        display: block;
        margin-top: 3px;
        font-size: 11px;
        color: #64748b;
        font-weight: 600;
    }

    .duty-line {
        line-height: 1.35;
        min-height: 18px;
    }
</style>

<div class="container py-4">
    <div class="topbar">
        <div>
            <h2 class="grid-title">График дежурств</h2>
        </div>

        <div class="top-actions">
            <a asp-controller="DutySchedule" asp-action="Edit" class="btn btn-outline-galaxy">
                Заполнить график
            </a>
            <a asp-controller="Schedule" asp-action="Index" class="btn btn-outline-galaxy">
                Назад
            </a>
        </div>
    </div>

    <div class="grid-card mb-4">
        <div class="p-3 pb-0">
            <h5 class="grid-title" style="font-size:18px;">Текущая неделя</h5>
        </div>

        <div class="scroll-wrap">
            <table class="duty-table">
                <thead>
                    <tr>
                        <th style="min-width:160px;">День</th>
                        @foreach (var lesson in Model.LessonTimes)
                        {
                            <th style="min-width:110px;">
                                @lesson.PairNumber пара
                                <span class="pair-time">@lesson.StartTime.ToString(@"hh\:mm")–@lesson.EndTime.ToString(@"hh\:mm")</span>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var date in Model.CurrentWeekDates)
                    {
                        if (date.DayOfWeek == DayOfWeek.Sunday)
                        {
                            continue;
                        }

                        var index = (int)date.DayOfWeek == 0 ? 6 : (int)date.DayOfWeek - 1;

                        <tr>
                            <td class="day-cell">
                                @dayNames[index]
                                <span class="date-note">@date.ToString("dd.MM.yyyy")</span>
                            </td>

                            @foreach (var lesson in Model.LessonTimes)
                            {
                                var values = GetCellValues(Model.CurrentWeekData, date, lesson.Id);
                                var empty = !values.Any();

                               <td class="duty-cell @(empty ? "empty" : "")">
    @if (empty)
    {
        <div>—</div>
        <div>&nbsp;</div>
    }
    else
    {
        <div>@values.ElementAtOrDefault(0)</div>
        <div>@(values.Count > 1 ? values[1] : "")</div> <!-- Отображаем второго дежурного -->
    }
</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="grid-card">
        <div class="p-3 pb-0">
            <h5 class="grid-title" style="font-size:18px;">Следующая неделя</h5>
        </div>

        <div class="scroll-wrap">
            <table class="duty-table">
                <thead>
                    <tr>
                        <th style="min-width:160px;">День</th>
                        @foreach (var lesson in Model.LessonTimes)
                        {
                            <th style="min-width:110px;">
                                @lesson.PairNumber пара
                                <span class="pair-time">@lesson.StartTime.ToString(@"hh\:mm")–@lesson.EndTime.ToString(@"hh\:mm")</span>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var date in Model.NextWeekDates)
                    {
                        if (date.DayOfWeek == DayOfWeek.Sunday)
                        {
                            continue;
                        }

                        var index = (int)date.DayOfWeek == 0 ? 6 : (int)date.DayOfWeek - 1;

                        <tr>
                            <td class="day-cell">
                                @dayNames[index]
                                <span class="date-note">@date.ToString("dd.MM.yyyy")</span>
                            </td>

                            @foreach (var lesson in Model.LessonTimes)
                            {
                                var values = GetCellValues(Model.NextWeekData, date, lesson.Id);
                                var empty = !values.Any();

                                <td class="duty-cell @(empty ? "empty" : "")">
                                    @if (empty)
                                    {
                                        <div class="duty-line">—</div>
                                        <div class="duty-line">&nbsp;</div>
                                    }
                                    else
                                    {
                                        <div class="duty-line">@values.ElementAtOrDefault(0)</div>
                                        <div class="duty-line">@(values.Count > 1 ? values[1] : "")</div>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>