@model MolServiceContracts.BindingModels.EquipmentMovementHistoryBindingModel

@{
    ViewData["Title"] = "Списание оборудования";
    Layout = "_Layout";
}

<style>
    :root {
        --galaxy: #0B1F5C;
        --planetary: #334EAC;
        --line: rgba(11, 31, 92, .15);
        --soft: #f8f9fc;
    }

    .page-card {
        max-width: 720px;
        margin: 0 auto;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: #fff;
        box-shadow: 0 8px 22px rgba(11, 31, 92, .06);
        overflow: hidden;
    }

    .page-card-header {
        padding: 18px 22px;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(180deg, #fff, var(--soft));
    }

    .page-card-body {
        padding: 22px;
    }

    .btn-galaxy {
        background-color: var(--galaxy);
        border-color: var(--galaxy);
        color: #fff;
    }

        .btn-galaxy:hover {
            background-color: var(--planetary);
            border-color: var(--planetary);
        }

    .btn-outline-galaxy {
        color: var(--galaxy);
        border-color: var(--galaxy);
    }

        .btn-outline-galaxy:hover {
            background-color: var(--galaxy);
            color: #fff;
        }

    .info-block {
        margin-bottom: 16px;
    }

    .info-label {
        color: #6c757d;
        font-size: 0.9rem;
    }

    .info-value {
        font-weight: 600;
        color: #0f172a;
    }
</style>

<div class="container py-4">
    <div class="page-card">
        <div class="page-card-header">
            <h2 class="mb-1">Списание оборудования</h2>
            <div class="text-muted">Оформление списания оборудования</div>
        </div>

        <div class="page-card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="info-block">
                <div class="info-label">Наименование</div>
                <div class="info-value">@ViewBag.MaterialTechnicalValueName</div>
            </div>

            <div class="info-block">
                <div class="info-label">Инвентарный номер</div>
                <div class="info-value">@ViewBag.InventoryNumber</div>
            </div>

            <div class="info-block">
                <div class="info-label">Текущее количество</div>
                <div class="info-value">@ViewBag.CurrentQuantity</div>
            </div>

            <div class="info-block mb-4">
                <div class="info-label">Аудитория</div>
                <div class="info-value">
                    @(string.IsNullOrWhiteSpace(ViewBag.ClassroomNumber) ? "Не закреплено" : ViewBag.ClassroomNumber)
                </div>
            </div>

            <form asp-action="Create" method="post">
                <input asp-for="MaterialTechnicalValueId" type="hidden" />

                <div class="mb-3">
                    <label asp-for="MoveDate" class="form-label">Дата списания</label>
                    <input asp-for="MoveDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="MoveDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label">Количество к списанию</label>
                    <input asp-for="Quantity" type="number" step="0.01" min="0.01" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Reason" class="form-label">Причина списания</label>
                    <textarea asp-for="Reason" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Comment" class="form-label">Комментарий</label>
                    <textarea asp-for="Comment" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Comment" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <a asp-controller="MaterialTechnicalValue"
                       asp-action="Details"
                       asp-route-id="@Model.MaterialTechnicalValueId"
                       class="btn btn-outline-galaxy">
                        Назад
                    </a>

                    <button type="submit" class="btn btn-galaxy">
                        Списать
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}