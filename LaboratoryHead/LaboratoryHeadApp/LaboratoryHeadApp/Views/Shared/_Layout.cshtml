<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Портал кафедры ИС</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --galaxy: #0B1F5C;
            --planetary: #334EAC;
            --sky: #D0E3FF;
        }

        /* Шапка */
        .app-navbar {
            background-color: var(--galaxy);
        }

            .app-navbar .navbar-brand,
            .app-navbar .nav-link {
                color: #ffffff;
            }

                .app-navbar .nav-link:hover,
                .app-navbar .nav-link:focus {
                    color: var(--sky);
                }

            .app-navbar .dropdown-menu {
                background-color: #ffffff;
            }

            .app-navbar .dropdown-item:hover {
                background-color: var(--planetary);
                color: #ffffff;
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar mb-3">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Портал кафедры ИС
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                    aria-expanded="false" aria-label="Переключатель навигации">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            Главная
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Mol" asp-action="Index">МОЛ и оборудование</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle"
                           href="#"
                           id="scheduleDropdown"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            Расписание
                        </a>

                        <ul class="dropdown-menu" aria-labelledby="scheduleDropdown">

                            <!-- Расписание занятий -->
                            <li class="dropdown-submenu">
                                <a class="dropdown-item dropdown-toggle"
                                   href="#">
                                    Расписание занятий
                                </a>

                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Schedule"
                                           asp-action="LessonsRooms">
                                            Аудитории
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Schedule"
                                           asp-action="LessonsTeachers">
                                            Преподаватели
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Schedule"
                                           asp-action="LessonsGroups">
                                            Группы
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <li><hr class="dropdown-divider" /></li>

                            <!-- Расписание дежурств -->
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="DutySchedule"
                                   asp-action="Index">
                                    Расписание дежурств
                                </a>
                            </li>
                        </ul>
                    </li>

                </ul>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">
                            Вход
                        </a>
                    </li>
                </ul>

            </div>

        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".dropdown-submenu > a").forEach(function (el) {
                el.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    const submenu = this.nextElementSibling;
                    if (submenu) {
                        submenu.style.display = (submenu.style.display === "block") ? "none" : "block";
                    }
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
