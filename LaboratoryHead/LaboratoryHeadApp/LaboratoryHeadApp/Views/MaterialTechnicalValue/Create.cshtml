@model MolServiceContracts.BindingModels.MaterialTechnicalValueBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Добавление МТЦ";
    Layout = "_Layout";
}

<style>
    :root {
        --galaxy: #0B1F5C;
        --planetary: #334EAC;
    }

    .btn-galaxy {
        background-color: var(--galaxy);
        border-color: var(--galaxy);
        color: #fff;
    }

    .btn-galaxy:hover,
    .btn-galaxy:focus {
        background-color: var(--planetary);
        border-color: var(--planetary);
        color: #fff;
    }

    .btn-outline-galaxy {
        color: var(--galaxy);
        border-color: var(--galaxy);
    }

    .btn-outline-galaxy:hover,
    .btn-outline-galaxy:focus {
        background-color: var(--galaxy);
        color: #fff;
    }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Добавление МТЦ</h2>
        <a asp-action="Index" class="btn btn-outline-galaxy">Назад</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="InventoryNumber" class="form-label"></label>
                    <input asp-for="InventoryNumber" class="form-control" />
                    <span asp-validation-for="InventoryNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MaterialResponsiblePersonId" class="form-label"></label>
                    <select asp-for="MaterialResponsiblePersonId"
                            asp-items="ViewBag.MaterialResponsiblePersons"
                            class="form-select">
                        <option value="">Выберите МОЛ</option>
                    </select>
                    <span asp-validation-for="MaterialResponsiblePersonId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ClassroomId" class="form-label"></label>
                    <select asp-for="ClassroomId"
                            asp-items="ViewBag.Classrooms"
                            class="form-select">
                        <option value="">Не закреплять за аудиторией</option>
                    </select>
                    <span asp-validation-for="ClassroomId" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-galaxy">Сохранить</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}