@model DepartmentContracts.ViewModels.StudentOrderBlockStudentViewModel
@using DepartmentDataModels.Enums

@{
    ViewData["Title"] = "Подробнее о студенте в приказе";

    string GetOrderTypeName(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "—";

        return value switch
        {
            nameof(StudentOrderType.Зачисление) => "Зачисление",
            nameof(StudentOrderType.Распределение) => "Распределение",
            nameof(StudentOrderType.Движение) => "Движение",
            nameof(StudentOrderType.ПереводНаКурс) => "Перевод на курс",
            nameof(StudentOrderType.ПереводВГруппу) => "Перевод в группу",
            nameof(StudentOrderType.ИзАкадема) => "Выход из академического отпуска",
            nameof(StudentOrderType.ВАкадем) => "Академический отпуск",
            nameof(StudentOrderType.ОтчислитьЗаНеуспевамость) => "Отчисление за неуспеваемость",
            nameof(StudentOrderType.ОтчислитьВСвязиСПереводом) => "Отчисление в связи с переводом",
            nameof(StudentOrderType.ОтчислитьПоСобственному) => "Отчисление по собственному желанию",
            nameof(StudentOrderType.ЗачислитьПоПереводу) => "Зачисление переводом",
            nameof(StudentOrderType.Восстановить) => "Восстановление",
            nameof(StudentOrderType.ОтчислитьПоЗавершению) => "Отчисление в связи с завершением обучения",
            nameof(StudentOrderType.ПродлАкадем) => "Продление академического отпуска",
            nameof(StudentOrderType.ОтчислитьЗаНевыходСАкадема) => "Отчисление за невыход из академического отпуска",
            _ => value
        };
    }
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о студенте в приказе</h2>
        <div class="d-flex gap-2">
            @*<a class="btn btn-sm btn-light" asp-controller="StudentOrderBlockStudents" asp-action="Update" asp-route-id="@Model.Id">Изменить</a>*@
            <a class="btn btn-sm btn-light" asp-controller="StudentOrders" asp-action="List">К списку</a>
        </div>
    </div>

    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Блок приказа
            </dt>
            <dd class="col-sm-8">
                @GetOrderTypeName(Model.StudentOrderBlock)
            </dd>

            <dt class="col-sm-4 text-muted">
                Студент
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.Student) ? "—" : Model.Student)
            </dd>

            <dt class="col-sm-4 text-muted">
                Из группы
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.StudentGroupFrom) ? "—" : Model.StudentGroupFrom)
            </dd>

            <dt class="col-sm-4 text-muted">
                В группу
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.StudentGroupTo) ? "—" : Model.StudentGroupTo)
            </dd>
        </dl>
    </div>
</div>