@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentContracts.ViewModels

@{
    ViewData["Title"] = "Удаление направления обучения";

    var directions = ViewBag.EducationDirectionsList as List<EducationDirectionViewModel>
                     ?? new List<EducationDirectionViewModel>();

    int? selectedId = ViewBag.SelectedId as int?;

    var selectItems = directions.Select(x => new SelectListItem
            {
                Value = x.Id.ToString(),
                Text = $"{x.Cipher} — {x.Title}",
                Selected = selectedId.HasValue && x.Id == selectedId.Value
            }).ToList();
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Удаление направления обучения</h2>
        <a class="btn btn-sm btn-light" asp-controller="EducationDirections" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label for="id" class="form-label">Выберите направление</label>
                <select id="id" name="id" class="form-select" asp-items="selectItems"></select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Удалить</button>
                <a class="btn btn-app-outline" asp-controller="EducationDirections" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>