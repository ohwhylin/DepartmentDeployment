@model DepartmentContracts.BindingModels.LecturerDepartmentPostBindingModel

@{
    ViewData["Title"] = "Редактирование кафедральной должности";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Редактирование кафедральной должности</h2>
        <a class="btn btn-sm btn-light" asp-controller="LecturerDepartmentPosts" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="DepartmentPostTitle" class="form-label">Наименование кафедральной должности</label>
                <input asp-for="DepartmentPostTitle" class="form-control" />
                <span asp-validation-for="DepartmentPostTitle" class="text-danger"></span>
            </div>

            @*<div class="mb-3">
                <label asp-for="Order" class="form-label">Порядок отображения</label>
                <input asp-for="Order" class="form-control" />
                <span asp-validation-for="Order" class="text-danger"></span>
            </div>*@

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="LecturerDepartmentPosts" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}