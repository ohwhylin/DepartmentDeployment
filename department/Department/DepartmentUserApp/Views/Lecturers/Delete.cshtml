@model DepartmentContracts.BindingModels.LecturerBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentContracts.ViewModels

@{
    ViewData["Title"] = "Удаление преподавателя";

    var lecturers = ViewBag.LecturersList as List<LecturerViewModel> ?? new List<LecturerViewModel>();
    int? selectedId = ViewBag.SelectedId as int?;

    var lecturerItems = lecturers
        .Select(x => new SelectListItem
                {
                    Value = x.Id.ToString(),
                    Text = $"{x.LastName} {x.FirstName} {x.Patronymic}".Trim(),
                    Selected = selectedId.HasValue && x.Id == selectedId.Value
                })
        .ToList();
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Удаление преподавателя</h2>
        <a class="btn btn-sm btn-light" asp-controller="Lecturers" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Id" class="form-label">Выберите преподавателя</label>
                <select asp-for="Id" class="form-select" asp-items="lecturerItems">
                    <option value="">Выберите значение</option>
                </select>
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>

            @if (lecturers.Count > 0)
            {
                <div class="mb-3">
                    <div class="hint">
                        Будет удалена выбранная запись преподавателя.
                    </div>
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Удалить</button>
                <a class="btn btn-app-outline" asp-controller="Lecturers" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts
    {
    <partial name="_ValidationScriptsPartial" />
}