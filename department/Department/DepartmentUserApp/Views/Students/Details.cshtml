@model DepartmentContracts.ViewModels.StudentViewModel
@using DepartmentDataModels.Enums
@using DepartmentContracts.ViewModels

@{
    ViewData["Title"] = "Подробнее о студенте";

    var movementHistory = ViewBag.StudentMovementHistory as List<StudentMovementHistoryViewModel>
        ?? new List<StudentMovementHistoryViewModel>();

    string GetStudentStateName(StudentState state) => state switch
    {
        StudentState.Учится => "Обучается",
        StudentState.Академ => "Академический отпуск",
        StudentState.Отчислен => "Отчислен",
        StudentState.Завершил => "Завершил",
        _ => state.ToString()
    };

    string GetOrderTypeName(StudentOrderType type) => type.ToString();
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о студенте</h2>
        <div class="d-flex gap-2">
            @*<a class="btn btn-sm btn-light" asp-controller="Students" asp-action="Update" asp-route-id="@Model.Id">Изменить</a>*@
            <a class="btn btn-sm btn-light" asp-controller="StudentGroups" asp-action="List">К списку</a>
        </div>
    </div>

    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Группа
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.StudentGroup) ? "—" : Model.StudentGroup)
            </dd>

            <dt class="col-sm-4 text-muted">
                Номер зачётной книжки
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.NumberOfBook) ? "—" : Model.NumberOfBook)
            </dd>

            <dt class="col-sm-4 text-muted">
                Имя
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.FirstName) ? "—" : Model.FirstName)
            </dd>

            <dt class="col-sm-4 text-muted">
                Фамилия
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.LastName) ? "—" : Model.LastName)
            </dd>

            <dt class="col-sm-4 text-muted">
                Отчество
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.Patronymic) ? "—" : Model.Patronymic)
            </dd>

            <dt class="col-sm-4 text-muted">
                Электронная почта
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.Email) ? "—" : Model.Email)
            </dd>

            <dt class="col-sm-4 text-muted">
                Статус студента
            </dt>
            <dd class="col-sm-8">
                @GetStudentStateName(Model.StudentState)
            </dd>

            <dt class="col-sm-4 text-muted">
                Описание
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)
            </dd>

            <dt class="col-sm-4 text-muted">
                Староста группы
            </dt>
            <dd class="col-sm-8">
                @(Model.IsSteward ? "Да" : "Нет")
            </dd>
        </dl>
    </div>
</div>

<div class="app-card mt-3">
    <div class="app-card-header">
        <h3 class="app-card-title mb-0">История движения студента</h3>
    </div>

    <div class="p-3">
        @if (movementHistory.Count == 0)
        {
            <div class="text-muted">
                История движения студента отсутствует.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Дата приказа</th>
                            <th>Номер приказа</th>
                            <th>Движение</th>
                            <th>Группа откуда</th>
                            <th>Группа куда</th>
                            <th>Описание</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in movementHistory)
                        {
                            <tr>
                                <td>
                                    @(item.OrderDate == DateTime.MinValue
                                                                ? "—"
                                                                : item.OrderDate.ToString("dd.MM.yyyy"))
                                                                                                    </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.OrderNumber)
                                                                ? "—"
                                                                : item.OrderNumber)
                                                                               </td>

                                <td>
                                    @GetOrderTypeName(item.StudentOrderType)
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.StudentGroupFromName)
                                                                ? "—"
                                                                : item.StudentGroupFromName)
                                                                                        </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.StudentGroupToName)
                                                                ? "—"
                                                                : item.StudentGroupToName)
                                                                                      </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.MovementDescription)
                                                                ? "—"
                                                                : item.MovementDescription)
                        </td>
                    </tr>
                                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>