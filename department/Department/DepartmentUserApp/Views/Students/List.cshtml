@{
    ViewData["Title"] = "Students";
}

<div class="list-shell">
    <div class="list-head">
        <div>
            <h2 class="list-title">Список студентов</h2>
            <div class="list-sub">Данные загружаются из 1С</div>
        </div>
        <div class="d-flex gap-2">
            <form asp-controller="Students" asp-action="Sync" method="post" class="d-inline">
                <button type="submit" class="btn btn-app-primary">Синхронизировать данные</button>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mt-3">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-3">
            @TempData["Error"]
        </div>
    }

    @if (ViewBag.StudentsList != null && ViewBag.StudentsList.Count > 0)
    {
        @foreach (var item in ViewBag.StudentsList)
        {
            <div class="entity-row">
                <div class="entity-accent"></div>
                <div class="entity-content">
                    <div class="entity-main">
                        <h5 class="entity-title">@item.LastName @item.FirstName @item.Patronymic</h5>
                        <div class="entity-meta">
                            <span class="meta-chip">Id: @item.Id</span>
                            @if (!string.IsNullOrWhiteSpace(item.StudentGroup))
                            {
                                <span class="meta-chip">@item.StudentGroup</span>
                            }
                            <span class="meta-chip">@item.NumberOfBook</span>
                            <span class="meta-chip">@item.StudentState</span>
                            @if (item.IsSteward)
                            {
                                <span class="meta-chip">Староста</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="entity-actions">
                    <div class="actions-stack">
                        <a class="btn btn-sm btn-app-outline"
                   asp-controller="Students"
                   asp-action="Details"
                   asp-route-id="@item.Id">
                            Подробнее
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-secondary mt-3">
            Данные отсутствуют. Выполните синхронизацию.
        </div>
    }
</div>
