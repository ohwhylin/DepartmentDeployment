@model DepartmentContracts.BindingModels.ClassroomBindingModel
@using DepartmentDataModels.Enums

@{
    ViewData["Title"] = "Добавление аудитории";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Добавление аудитории</h2>
        <a class="btn btn-sm btn-light" asp-controller="Classrooms" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="accordion" id="createAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#createMainBlock">
                            Основные данные
                        </button>
                    </h2>

                    <div id="createMainBlock" class="accordion-collapse collapse show">
                        <div class="accordion-body">
                            <div class="mb-3">
                                <label asp-for="Number" class="form-label">Номер аудитории</label>
                                <input asp-for="Number" class="form-control" />
                                <span asp-validation-for="Number" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Type" class="form-label">Тип аудитории</label>
                                <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<ClassroomTypes>()"></select>
                                <span asp-validation-for="Type" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Capacity" class="form-label">Вместимость</label>
                                <input asp-for="Capacity" class="form-control" />
                                <span asp-validation-for="Capacity" class="text-danger"></span>
                            </div>

                            <div class="form-check mb-3">
                                <input asp-for="NotUseInSchedule" class="form-check-input" />
                                <label asp-for="NotUseInSchedule" class="form-check-label">
                                    Не участвует в расписании
                                </label>
                            </div>
                            <span asp-validation-for="NotUseInSchedule" class="text-danger"></span>

                            <div class="form-check mb-3">
                                <input asp-for="HasProjector" class="form-check-input" />
                                <label asp-for="HasProjector" class="form-check-label">
                                    Имеется проектор
                                </label>
                            </div>
                            <span asp-validation-for="HasProjector" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="Classrooms" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}