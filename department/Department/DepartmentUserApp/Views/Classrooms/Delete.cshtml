@model DepartmentContracts.BindingModels.ClassroomBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentContracts.ViewModels

@{
    ViewData["Title"] = "Удаление аудитории";

    var classrooms = ViewBag.ClassroomsList as List<ClassroomViewModel> ?? new List<ClassroomViewModel>();
    int? selectedId = ViewBag.SelectedId as int?;

    var classroomItems = classrooms
        .Select(x => new SelectListItem
                {
                    Value = x.Id.ToString(),
                    Text = string.IsNullOrWhiteSpace(x.Number) ? $"Аудитория {x.Id}" : $"Аудитория {x.Number}",
                    Selected = selectedId.HasValue && x.Id == selectedId.Value
                })
        .ToList();
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Удаление аудитории</h2>
        <a class="btn btn-sm btn-light" asp-controller="Classrooms" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Id" class="form-label">Выберите аудиторию</label>
                <select asp-for="Id" class="form-select" asp-items="classroomItems">
                    <option value="">Выберите значение</option>
                </select>
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Удалить</button>
                <a class="btn btn-app-outline" asp-controller="Classrooms" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}