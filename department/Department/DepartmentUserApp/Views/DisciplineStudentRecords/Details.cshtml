@model DepartmentContracts.ViewModels.DisciplineStudentRecordViewModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Подробнее о DisciplineStudentRecord";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее об отметке</h2>
        <div class="d-flex gap-2">
            @*<a class="btn btn-sm btn-light" asp-controller="DisciplineStudentRecords" asp-action="Update">Изменить</a>*@
            <a class="btn btn-sm btn-light" asp-controller="DisciplineStudentRecords" asp-action="List">К списку</a>
        </div>
    </div>
    <div class="p-3">
        <dl class="row mb-0">
            @*<dt class="col-sm-4 text-muted">
                Id
            </dt>
            <dd class="col-sm-8">
                @Model.Id
            </dd>*@
            <dt class="col-sm-4 text-muted">
                Дисциплина
            </dt>
            <dd class="col-sm-8">
                @Model.Discipline
            </dd>
            <dt class="col-sm-4 text-muted">
                Студент
            </dt>
            <dd class="col-sm-8">
                @Model.Student
            </dd>
            <dt class="col-sm-4 text-muted">
                Семестр
            </dt>
            <dd class="col-sm-8">
                @Model.Semester
            </dd>
            <dt class="col-sm-4 text-muted">
                Вариант
            </dt>
            <dd class="col-sm-8">
                @Model.Variant
            </dd>
            <dt class="col-sm-4 text-muted">
                Под группа
            </dt>
            <dd class="col-sm-8">
                @Model.SubGroup
            </dd>
        </dl>
    </div>
</div>
