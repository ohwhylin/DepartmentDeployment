@model DepartmentContracts.ViewModels.StudentGroupViewModel
@using DepartmentDataModels.Enums

@{
    ViewData["Title"] = "Подробнее о группе";

    string GetCourseName(AcademicCourse course) => course switch
    {
        AcademicCourse.Course_1 => "Первый курс",
        AcademicCourse.Course_2 => "Второй курс",
        AcademicCourse.Course_3 => "Третий курс",
        AcademicCourse.Course_4 => "Четвёртый курс",
        _ => course.ToString()
    };
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о группе</h2>
        <div class="d-flex gap-2">
            @*<a class="btn btn-sm btn-light" asp-controller="StudentGroups" asp-action="Update" asp-route-id="@Model.Id">Изменить</a>*@
            <a class="btn btn-sm btn-light" asp-controller="StudentGroups" asp-action="List">К списку</a>
        </div>
    </div>

    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Направление обучения
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.EducationDirection) ? "—" : Model.EducationDirection)
            </dd>

            <dt class="col-sm-4 text-muted">
                Куратор
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.Curator) ? "—" : Model.Curator)
            </dd>

            <dt class="col-sm-4 text-muted">
                Название группы
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.GroupName) ? "—" : Model.GroupName)
            </dd>

            <dt class="col-sm-4 text-muted">
                Курс
            </dt>
            <dd class="col-sm-8">
                @GetCourseName(Model.Course)
            </dd>
        </dl>
    </div>
</div>