@model DepartmentContracts.BindingModels.LecturerStudyPostBindingModel

@{
    ViewData["Title"] = "Редактирование учебной должности";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Редактирование учебной должности</h2>
        <a class="btn btn-sm btn-light" asp-controller="LecturerStudyPosts" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="StudyPostTitle" class="form-label">Наименование учебной должности</label>
                <input asp-for="StudyPostTitle" class="form-control" />
                <span asp-validation-for="StudyPostTitle" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Hours" class="form-label">Количество часов</label>
                <input asp-for="Hours" class="form-control" />
                <span asp-validation-for="Hours" class="text-danger"></span>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="LecturerStudyPosts" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}