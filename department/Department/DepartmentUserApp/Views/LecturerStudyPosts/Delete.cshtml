@model DepartmentContracts.BindingModels.LecturerStudyPostBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentContracts.ViewModels

@{
    ViewData["Title"] = "Удаление учебной должности";

    var posts = ViewBag.LecturerStudyPostsList as List<LecturerStudyPostViewModel> ?? new List<LecturerStudyPostViewModel>();
    int? selectedId = ViewBag.SelectedId as int?;

    var selectItems = posts.Select(x => new SelectListItem
            {
                Value = x.Id.ToString(),
                Text = x.StudyPostTitle,
                Selected = selectedId.HasValue && x.Id == selectedId.Value
            }).ToList();
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Удаление учебной должности</h2>
        <a class="btn btn-sm btn-light" asp-controller="LecturerStudyPosts" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Id" class="form-label">Выберите учебную должность</label>
                <select asp-for="Id" class="form-select" asp-items="selectItems">
                    <option value="">Выберите значение</option>
                </select>
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Удалить</button>
                <a class="btn btn-app-outline" asp-controller="LecturerStudyPosts" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}