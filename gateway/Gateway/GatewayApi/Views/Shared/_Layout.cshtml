<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Портал кафедры</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --galaxy: #0B1F5C;
            --planetary: #334EAC;
            --sky: #D0E3FF;
        }

        body {
            background: #f6f8fc;
        }

        .app-navbar {
            background-color: var(--galaxy);
        }

        .app-navbar .navbar-brand,
        .app-navbar .nav-link,
        .app-navbar .navbar-text {
            color: #ffffff;
        }

        .app-navbar .nav-link:hover,
        .app-navbar .nav-link:focus {
            color: var(--sky);
        }

        .app-card {
            border: 1px solid var(--sky);
            border-radius: 12px;
            box-shadow: 0 6px 16px rgba(0,0,0,.06);
            background: #fff;
        }

        .app-card-header {
            background: var(--galaxy);
            color: #fff;
            padding: 12px 16px;
            border-top-left-radius: 12px;
            border-top-right-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .app-card-title {
            margin: 0;
            font-weight: 600;
        }

        .btn-app-primary {
            background: var(--galaxy);
            border-color: var(--galaxy);
            color: #fff;
        }

        .btn-app-primary:hover,
        .btn-app-primary:focus {
            background: var(--planetary);
            border-color: var(--planetary);
            color: #fff;
        }

        .btn-app-outline {
            background: transparent;
            border-color: var(--galaxy);
            color: var(--galaxy);
        }

        .btn-app-outline:hover,
        .btn-app-outline:focus {
            background: var(--galaxy);
            border-color: var(--galaxy);
            color: #fff;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--sky);
            box-shadow: 0 0 0 .2rem rgba(208, 227, 255, 0.6);
        }

        .hint {
            font-size: .9rem;
            color: var(--galaxy);
            opacity: .75;
        }

        .auth-shell {
            min-height: calc(100vh - 90px);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-card {
            width: 100%;
            max-width: 520px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar mb-4">
        <div class="container">
            <a class="navbar-brand" href="@(Context.Request.PathBase + "/core/")">
                Портал кафедры
            </a>

            <div class="d-flex align-items-center gap-3">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <span class="navbar-text">
                        @User.Identity.Name
                    </span>

                    <form method="post" action="@(Context.Request.PathBase + "/auth/logout")" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-light">
                            Выйти
                        </button>
                    </form>
                }
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    @RenderSection("Styles", required: false)
    @RenderSection("Scripts", required: false)

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>