@model DepartmentLoadApp.Models.SemesterPeriod

@{
    ViewData["Title"] = "Добавить семестр";
}

<h1>Добавить семестр</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="AcademicYear" class="form-label">Учебный год</label>
        <input asp-for="AcademicYear" class="form-control" placeholder="2025-2026" />
    </div>

    <div class="mb-3">
        <label asp-for="Season" class="form-label">Сезон</label>
        <select asp-for="Season" class="form-select">
            <option value="Осень">Осень</option>
            <option value="Весна">Весна</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label">Дата начала</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label">Дата окончания</label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>