@model List<DepartmentLoadApp.Models.SemesterPeriod>

@{
    ViewData["Title"] = "Семестры";
}

<h1>Семестры</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить семестр</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Учебный год</th>
            <th>Сезон</th>
            <th>Дата начала</th>
            <th>Дата окончания</th>
            <th style="width: 180px;">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.AcademicYear</td>
                <td>@item.Season</td>
                <td>@item.StartDate.ToString("dd.MM.yyyy")</td>
                <td>@item.EndDate.ToString("dd.MM.yyyy")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Удалить семестр?');">
                            Удалить
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>