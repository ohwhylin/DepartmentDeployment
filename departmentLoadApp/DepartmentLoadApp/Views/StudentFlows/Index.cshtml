@model List<DepartmentLoadApp.Models.StudentFlow>

@{
    ViewData["Title"] = "Потоки";
}

<h1>Потоки</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить поток</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Учебный год</th>
            <th>Название потока</th>
            <th>Код направления</th>
            <th>Курс</th>
            <th>Уровень</th>
            <th>Группы</th>
            <th>Студентов</th>
            <th style="width: 180px;">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.AcademicYear</td>
                <td>@item.FlowName</td>
                <td>@item.DirectionCode</td>
                <td>@item.Course</td>
                <td>@item.EducationLevel</td>
                <td>@item.GroupNames</td>
                <td>@item.StudentsCount</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Удалить поток?');">
                            Удалить
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>