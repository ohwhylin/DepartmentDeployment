@{
    ViewData["Title"] = "Главная";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="mb-3">Модуль расчета нагрузки преподавателей</h1>
        <p class="text-muted mb-0">
            Система предназначена для автоматического расчета учебной нагрузки
            и формирования индивидуальных планов преподавателей кафедры.
        </p>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                <div>
                    <h4 class="mb-2">Синхронизация с главным модулем</h4>
                    <p class="text-muted mb-0">
                        Синхронизирует таблицы преподавателей, учебные планы и записи учебных планов с главным модулем.
                    </p>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <button id="syncCoreBtn" type="button" class="btn btn-primary">
                        Синхронизировать с ядром
                    </button>
                </div>
            </div>

            <div id="syncStatus" class="mt-3" style="display:none;"></div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="card-title">Расчет необходимой нагрузки</h5>
                    <p class="card-text text-muted">
                        Автоматический расчет количества часов на основе норм времени
                        и контингента студентов.
                    </p>
                    <a asp-controller="WorkloadCalculation" asp-action="Index" class="btn btn-outline-primary">
                        Открыть
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="card-title">Распределение нагрузки</h5>
                    <p class="card-text text-muted">
                        Ручное распределение рассчитанных часов между преподавателями кафедры.
                    </p>
                    <a asp-controller="WorkloadDistribution" asp-action="Index" class="btn btn-outline-primary">
                        Открыть
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="card-title">Индивидуальные планы</h5>
                    <p class="card-text text-muted">
                        Просмотр и формирование индивидуальных планов преподавателей.
                    </p>
                    <a asp-controller="IndividualPlans" asp-action="Index" class="btn btn-outline-primary">
                        Открыть
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const syncButton = document.getElementById('syncCoreBtn');
        const syncStatus = document.getElementById('syncStatus');

        function showStatus(message, type) {
            syncStatus.style.display = 'block';
            syncStatus.className = `alert alert-${type} mt-3`;
            syncStatus.textContent = message;
        }

        syncButton.addEventListener('click', async function () {
            syncButton.disabled = true;
            syncButton.textContent = 'Синхронизация...';
            showStatus('Запущена синхронизация данных с ядром...', 'info');

            try {
                const response = await fetch('/api/sync/all', {
                    method: 'POST'
                });

                const text = await response.text();

                if (!response.ok) {
                    showStatus(`Ошибка синхронизации: ${text}`, 'danger');
                    return;
                }

                showStatus('Синхронизация успешно завершена.', 'success');
            } catch (error) {
                showStatus('Не удалось выполнить синхронизацию. Проверь Docker, доступность core-api и сеть между контейнерами.', 'danger');
            } finally {
                syncButton.disabled = false;
                syncButton.textContent = 'Синхронизировать с ядром';
            }
        });
    </script>
}