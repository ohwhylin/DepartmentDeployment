@model DepartmentLoadApp.ViewModels.Practice.PracticeWorkloadPageViewModel

@{
    ViewData["Title"] = "Практики";
}

<h1 class="mb-4">Расчет нагрузки по практикам</h1>

<form asp-action="ImportFromAcademicPlan" method="post" class="row g-3 align-items-end mb-4">
    @Html.AntiForgeryToken()

    <div class="col-auto">
        <label class="form-label">Год начала расчета</label>
        <select name="startYear" class="form-select">
            @foreach (var year in Model.AvailableYearStarts)
            {
                if (year == Model.SelectedYearStart)
                {
                    <option value="@year" selected>@year</option>
                }
                else
                {
                    <option value="@year">@year</option>
                }
            }
        </select>
    </div>

    <div class="col-auto">
        <label class="form-label">Учебный год</label>
        <input class="form-control" value="@Model.SelectedYear" readonly />
    </div>

    <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary">Рассчитать</button>
    </div>
</form>
<form asp-controller="WorkloadCalculation" asp-action="ExportToExcel" method="get" class="d-inline">
    <input type="hidden" name="startYear" value="@Model.SelectedYearStart" />
    <button type="submit" class="btn btn-success">
        Выгрузить в Excel
    </button>
</form>
<div class="mb-3 d-flex gap-2">
    <a asp-controller="WorkloadCalculation"
       asp-action="Index"
       asp-route-startYear="@Model.SelectedYearStart"
       class="btn btn-outline-primary">
        Дисциплины
    </a>

    <a asp-controller="PracticeCalculation"
       asp-action="Index"
       asp-route-startYear="@Model.SelectedYearStart"
       class="btn btn-primary">
        Практики
    </a>

    <a asp-controller="GiaCalculation"
       asp-action="Index"
       asp-route-startYear="@Model.SelectedYearStart"
       class="btn btn-outline-primary">
        ГИА
    </a>
</div>

<p class="text-muted">
    Для практик вручную задается только количество недель. Остальные данные
    подтягиваются автоматически из учебных планов, контингента и норм времени.
</p>

<form asp-action="Save" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="SelectedYearStart" />
    <input type="hidden" asp-for="SelectedYear" />

    <div class="table-responsive">
        <table class="table table-bordered table-striped align-middle">
            <thead class="table-light text-center align-middle">
                <tr>
                    <th>Семестр</th>
                    <th>Форма обучения</th>
                    <th>Код направления</th>
                    <th>Вид практики</th>
                    <th>Курс</th>
                    <th>Групп</th>
                    <th>Студентов</th>
                    <th>Количество недель</th>
                    <th>Итого</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows == null || !Model.Rows.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            По выбранному учебному году данных пока нет
                        </td>
                    </tr>
                }
                else
                {
                    @for (int i = 0; i < Model.Rows.Count; i++)
                    {
                        <tr>
                            <td>
                                @Model.Rows[i].SemesterName

                                <input type="hidden" name="Rows[@i].Id" value="@Model.Rows[i].Id" />
                                <input type="hidden" name="Rows[@i].PlanYear" value="@Model.Rows[i].PlanYear" />
                                <input type="hidden" name="Rows[@i].AcademicPlanId" value="@Model.Rows[i].AcademicPlanId" />
                                <input type="hidden" name="Rows[@i].AcademicPlanRecordId" value="@Model.Rows[i].AcademicPlanRecordId" />
                                <input type="hidden" name="Rows[@i].PracticeName" value="@Model.Rows[i].PracticeName" />
                                <input type="hidden" name="Rows[@i].DirectionCode" value="@Model.Rows[i].DirectionCode" />
                                <input type="hidden" name="Rows[@i].DirectionName" value="@Model.Rows[i].DirectionName" />
                                <input type="hidden" name="Rows[@i].Course" value="@Model.Rows[i].Course" />
                                <input type="hidden" name="Rows[@i].SemesterName" value="@Model.Rows[i].SemesterName" />
                                <input type="hidden" name="Rows[@i].EducationForm" value="@Model.Rows[i].EducationForm" />
                                <input type="hidden" name="Rows[@i].StudentsCount" value="@Model.Rows[i].StudentsCount" />
                                <input type="hidden" name="Rows[@i].GroupCount" value="@Model.Rows[i].GroupCount" />
                                <input type="hidden" name="Rows[@i].TotalHours" value="@Model.Rows[i].TotalHours.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                            </td>

                            <td>@Model.Rows[i].EducationForm</td>
                            <td>@Model.Rows[i].DirectionCode</td>
                            <td>@Model.Rows[i].PracticeName</td>
                            <td>@Model.Rows[i].Course</td>
                            <td>@Model.Rows[i].GroupCount</td>
                            <td>@Model.Rows[i].StudentsCount</td>

                            <td style="max-width: 140px;">
                                <input type="number"
                                       min="0"
                                       step="1"
                                       name="Rows[@i].WeeksCount"
                                       value="@Model.Rows[i].WeeksCount"
                                       class="form-control" />
                            </td>

                            <td>@Model.Rows[i].TotalHours.ToString("0.##")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.Rows != null && Model.Rows.Any())
    {
        <button type="submit" class="btn btn-primary">Сохранить недели и пересчитать</button>
    }
</form>