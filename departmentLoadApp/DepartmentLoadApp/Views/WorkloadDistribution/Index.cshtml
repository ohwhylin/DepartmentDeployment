@model DepartmentLoadApp.ViewModels.WorkloadDistribution.WorkloadDistributionPageViewModel

@{
    ViewData["Title"] = "Распределение нагрузки";
}

<h1 class="mb-4">Распределение нагрузки на преподавателей</h1>

<div class="d-flex flex-wrap gap-3 align-items-end mb-4">
    <div>
        <label class="form-label fw-semibold d-block">Год начала распределения</label>
        <div class="btn-group" role="group">
            @foreach (var year in Model.AvailableYearStarts)
            {
                <a asp-action="Index"
                   asp-route-startYear="@year"
                   asp-route-selectedLecturerId="@Model.SelectedLecturerId"
                   class="btn @(year == Model.SelectedYearStart ? "btn-primary" : "btn-outline-primary")">
                    @year
                </a>
            }
        </div>
    </div>

    <div style="min-width: 170px;">
        <label class="form-label fw-semibold">Учебный год</label>
        <input class="form-control" value="@Model.SelectedYear" readonly />
    </div>

    <div class="d-flex gap-2">
        <a asp-controller="WorkloadCalculation"
           asp-action="Index"
           asp-route-startYear="@Model.SelectedYearStart"
           class="btn btn-outline-secondary">
            К расчетам
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="alert alert-info">
    Часы берутся из уже рассчитанных дисциплин, практик и ГИА за выбранный учебный год.
    Все значения округляются до целых часов по математическим правилам.
    Ассистентам нельзя назначать лекции.
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Всего часов</div>
                <div class="fs-3 fw-bold">@Model.TotalHours</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 border-success">
            <div class="card-body">
                <div class="text-muted small">Распределено</div>
                <div class="fs-3 fw-bold text-success">@Model.AssignedHours</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 border-warning">
            <div class="card-body">
                <div class="text-muted small">Осталось распределить</div>
                <div class="fs-3 fw-bold text-warning">@Model.RemainingHours</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 @(Model.OverloadedLecturerCount > 0 ? "border-danger" : "")">
            <div class="card-body">
                <div class="text-muted small">Перегружено преподавателей</div>
                <div class="fs-3 fw-bold @(Model.OverloadedLecturerCount > 0 ? "text-danger" : "")">
                    @Model.OverloadedLecturerCount
                </div>
            </div>
        </div>
    </div>
</div>

<h2 class="h4 mb-3">Преподаватели</h2>

@if (!Model.Lecturers.Any())
{
    <div class="alert alert-warning">Преподаватели не найдены.</div>
}
else
{
    <div class="accordion mb-5" id="lecturersAccordion">
        @for (var i = 0; i < Model.Lecturers.Count; i++)
        {
            var card = Model.Lecturers[i];
            var collapseId = $"collapse-{card.LecturerId}";
            var headingId = $"heading-{card.LecturerId}";
            var isOpen = card.LecturerId == Model.SelectedLecturerId;

            <div class="accordion-item mb-3" id="lecturer-@card.LecturerId">
                <h2 class="accordion-header" id="@headingId">
                    <button class="accordion-button @(isOpen ? "" : "collapsed")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapseId"
                            aria-expanded="@(isOpen ? "true" : "false")"
                            aria-controls="@collapseId">
                        <div class="w-100 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center pe-3">
                            <div class="me-3">
                                <div class="fw-bold">@card.LecturerDisplayName</div>
                                <div class="text-muted small">
                                    @card.LecturerStudyPostTitle
                                    · ставка @card.Rate.ToString("0.##")
                                    · норма @card.NormHours
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mt-2 mt-lg-0">
                                <span class="badge bg-secondary">Назначено: @card.AssignedHours</span>
                                <span class="badge bg-dark">Лимит: @card.LimitHours</span>

                                @if (card.IsOverloaded)
                                {
                                    <span class="badge bg-danger">Перегруз: @(card.AssignedHours - card.LimitHours)</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Остаток: @card.RemainingHours</span>
                                }

                                @if (card.IsAssistant)
                                {
                                    <span class="badge bg-warning text-dark">Ассистент</span>
                                }
                            </div>
                        </div>
                    </button>
                </h2>

                <div id="@collapseId"
                     class="accordion-collapse collapse @(isOpen ? "show" : "")"
                     aria-labelledby="@headingId"
                     data-bs-parent="#lecturersAccordion">
                    <div class="accordion-body">
                        <div class="row g-4">
                            <div class="col-xl-4">
                                <div class="card h-100">
                                    <div class="card-header fw-semibold">Параметры преподавателя на @Model.SelectedYear</div>
                                    <div class="card-body">
                                        <form asp-action="SaveLecturerPlan" method="post">
                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="SelectedYearStart" value="@Model.SelectedYearStart" />
                                            <input type="hidden" name="SelectedLecturerId" value="@card.LecturerId" />
                                            <input type="hidden" name="LecturerId" value="@card.LecturerId" />

                                            <div class="mb-3">
                                                <label class="form-label">Учебная должность</label>
                                                <select class="form-select" name="LecturerStudyPostId">
                                                    <option value="">Не выбрана</option>
                                                    @foreach (var post in Model.StudyPosts)
                                                    {
                                                        <option value="@post.Id" selected="@(post.Id == card.LecturerStudyPostId)">
                                                            @post.Title (@post.NormHours ч.)
                                                        </option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label">Ставка</label>
                                                <input class="form-control"
                                                       type="text"
                                                       name="Rate"
                                                       value="@card.Rate.ToString("0.##")"
                                                       placeholder="Например: 1, 0,5, 0,25"
                                                       inputmode="decimal" />
                                            </div>

                                            <div class="small text-muted mb-3">
                                                Лимит считается как <strong>норма по должности × ставка</strong>.
                                            </div>

                                            <button type="submit" class="btn btn-primary">
                                                Сохранить параметры
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-8">
                                <div class="card mb-4">
                                    <div class="card-header fw-semibold">Назначить нагрузку</div>
                                    <div class="card-body">
                                        @if (!card.AvailableItems.Any())
                                        {
                                            <div class="text-muted">Свободных элементов нагрузки для назначения нет.</div>
                                        }
                                        else
                                        {
                                            <form asp-action="AddAssignment" method="post" class="row g-2 align-items-end">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="SelectedYearStart" value="@Model.SelectedYearStart" />
                                                <input type="hidden" name="SelectedLecturerId" value="@card.LecturerId" />
                                                <input type="hidden" name="LecturerId" value="@card.LecturerId" />

                                                <div class="col-lg-9">
                                                    <label class="form-label">Элемент нагрузки</label>
                                                    <select class="form-select" name="ItemKey">
                                                        @foreach (var group in card.AvailableItems.GroupBy(x => x.SourceTypeDisplayName))
                                                        {
                                                            <optgroup label="@group.Key">
                                                                @foreach (var item in group)
                                                                {
                                                                    <option value="@item.ItemKey">@item.SelectText</option>
                                                                }
                                                            </optgroup>
                                                        }
                                                    </select>
                                                </div>

                                                <div class="col-lg-3">
                                                    <button type="submit" class="btn btn-success w-100">
                                                        Назначить
                                                    </button>
                                                </div>
                                            </form>
                                        }
                                    </div>
                                </div>

                                <div class="card">
                                    <div class="card-header fw-semibold">Назначенная нагрузка</div>
                                    <div class="card-body">
                                        @if (!card.Assignments.Any())
                                        {
                                            <div class="text-muted">У этого преподавателя пока нет назначенной нагрузки.</div>
                                        }
                                        else
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm align-middle">
                                                    <thead>
                                                        <tr>
                                                            <th>Источник</th>
                                                            <th>Нагрузка</th>
                                                            <th>Часы</th>
                                                            <th style="min-width: 310px;">Изменить</th>
                                                            <th></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var assignment in card.Assignments)
                                                        {
                                                            <tr class="@(card.IsOverloaded ? "table-danger" : "")">
                                                                <td>
                                                                    <div class="fw-semibold">@assignment.SourceTypeDisplayName</div>
                                                                    <div class="small text-muted">@assignment.Subtitle</div>
                                                                </td>
                                                                <td>
                                                                    <div class="fw-semibold">@assignment.Title</div>
                                                                    <div class="small text-muted">@assignment.ElementDisplayName</div>
                                                                    <div class="small text-muted">
                                                                        Всего по элементу: @assignment.TotalItemHours,
                                                                        осталось нераспределенным: @assignment.RemainingItemHours
                                                                    </div>
                                                                </td>
                                                                <td class="fw-bold">@assignment.AssignedHours</td>
                                                                <td>
                                                                    <div class="d-flex flex-wrap gap-1">
                                                                        <form asp-action="ChangeAssignmentHours" method="post" class="d-inline">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="SelectedYearStart" value="@Model.SelectedYearStart" />
                                                                            <input type="hidden" name="SelectedLecturerId" value="@card.LecturerId" />
                                                                            <input type="hidden" name="AssignmentId" value="@assignment.AssignmentId" />
                                                                            <button type="submit" name="Delta" value="-10" class="btn btn-outline-secondary btn-sm" @(assignment.CanDecrease ? null : "disabled")>-10</button>
                                                                        </form>

                                                                        <form asp-action="ChangeAssignmentHours" method="post" class="d-inline">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="SelectedYearStart" value="@Model.SelectedYearStart" />
                                                                            <input type="hidden" name="SelectedLecturerId" value="@card.LecturerId" />
                                                                            <input type="hidden" name="AssignmentId" value="@assignment.AssignmentId" />
                                                                            <button type="submit" name="Delta" value="-5" class="btn btn-outline-secondary btn-sm" @(assignment.CanDecrease ? null : "disabled")>-5</button>
                                                                        </form>

                                                                        <form asp-action="ChangeAssignmentHours" method="post" class="d-inline">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="SelectedYearStart" value="@Model.SelectedYearStart" />
                                                                            <input type="hidden" name="SelectedLecturerId" value="@card.LecturerId" />
                                                                            <input type="hidden" name="AssignmentId" value="@assignment.AssignmentId" />
                                                                            <button type="submit" name="Delta" value="-1" class="btn btn-outline-secondary btn-sm" @(assignment.CanDecrease ? null : "disabled")>-1</button>
                                                                        </form>

                                                                        <form asp-action="ChangeAssignmentHours" method="post" class="d-inline">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="SelectedYearStart" value="@Model.SelectedYearStart" />
                                                                            <input type="hidden" name="SelectedLecturerId" value="@card.LecturerId" />
                                                                            <input type="hidden" name="AssignmentId" value="@assignment.AssignmentId" />
                                                                            <button type="submit" name="Delta" value="1" class="btn btn-outline-primary btn-sm" @(assignment.CanIncrease ? null : "disabled")>+1</button>
                                                                        </form>

                                                                        <form asp-action="ChangeAssignmentHours" method="post" class="d-inline">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="SelectedYearStart" value="@Model.SelectedYearStart" />
                                                                            <input type="hidden" name="SelectedLecturerId" value="@card.LecturerId" />
                                                                            <input type="hidden" name="AssignmentId" value="@assignment.AssignmentId" />
                                                                            <button type="submit" name="Delta" value="5" class="btn btn-outline-primary btn-sm" @(assignment.CanIncrease ? null : "disabled")>+5</button>
                                                                        </form>

                                                                        <form asp-action="ChangeAssignmentHours" method="post" class="d-inline">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="SelectedYearStart" value="@Model.SelectedYearStart" />
                                                                            <input type="hidden" name="SelectedLecturerId" value="@card.LecturerId" />
                                                                            <input type="hidden" name="AssignmentId" value="@assignment.AssignmentId" />
                                                                            <button type="submit" name="Delta" value="10" class="btn btn-outline-primary btn-sm" @(assignment.CanIncrease ? null : "disabled")>+10</button>
                                                                        </form>

                                                                        <form asp-action="FillAssignmentToRemaining" method="post" class="d-inline">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="startYear" value="@Model.SelectedYearStart" />
                                                                            <input type="hidden" name="assignmentId" value="@assignment.AssignmentId" />
                                                                            <button type="submit" class="btn btn-outline-success btn-sm">
                                                                                Остаток
                                                                            </button>
                                                                        </form>
                                                                    </div>
                                                                </td>
                                                                <td class="text-end">
                                                                    <form asp-action="DeleteAssignment" method="post">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="SelectedYearStart" value="@Model.SelectedYearStart" />
                                                                        <input type="hidden" name="SelectedLecturerId" value="@card.LecturerId" />
                                                                        <input type="hidden" name="AssignmentId" value="@assignment.AssignmentId" />
                                                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                                                            Удалить
                                                                        </button>
                                                                    </form>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<h2 class="h4 mb-3">Осталось распределить</h2>

@if (!Model.RemainingItems.Any())
{
    <div class="alert alert-success">Вся нагрузка распределена.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-sm align-middle">
            <thead>
                <tr>
                    <th>Источник</th>
                    <th>Наименование</th>
                    <th>Элемент</th>
                    <th>Всего</th>
                    <th>Уже распределено</th>
                    <th>Осталось</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.RemainingItems)
                {
                    <tr>
                        <td>@item.SourceTypeDisplayName</td>
                        <td>
                            <div class="fw-semibold">@item.Title</div>
                            <div class="small text-muted">@item.Subtitle</div>
                        </td>
                        <td>@item.ElementDisplayName</td>
                        <td>@item.TotalHours</td>
                        <td>@item.AssignedHours</td>
                        <td class="fw-bold text-warning">@item.RemainingHours</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}