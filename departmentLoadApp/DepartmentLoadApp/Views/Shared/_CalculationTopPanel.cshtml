@model DepartmentLoadApp.ViewModels.Shared.CalculationTopPanelViewModel

@{
    var controllerName = Model.ActiveTab switch
    {
        "workload" => "WorkloadCalculation",
        "practice" => "PracticeCalculation",
        "gia" => "GiaCalculation",
        _ => "WorkloadCalculation"
    };
}

<form asp-controller="@controllerName" asp-action="ImportFromAcademicPlan" method="post" class="row g-3 align-items-end mb-4">
    @Html.AntiForgeryToken()

    <div class="col-auto">
        <label class="form-label">Год начала расчета</label>
        <select name="startYear" class="form-select">
            @foreach (var year in Model.AvailableYearStarts)
            {
                if (year == Model.SelectedYearStart)
                {
                    <option value="@year" selected>@year</option>
                }
                else
                {
                    <option value="@year">@year</option>
                }
            }
        </select>
    </div>

    <div class="col-auto">
        <label class="form-label">Учебный год</label>
        <input class="form-control" value="@Model.SelectedYear" readonly />
    </div>

    <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary">Рассчитать</button>

        <a asp-controller="@controllerName"
           asp-action="ExportToExcel"
           asp-route-startYear="@Model.SelectedYearStart"
           class="btn btn-outline-success">
            Выгрузить в Excel
        </a>
    </div>
</form>

<div class="mb-3 d-flex gap-2">
    <a asp-controller="WorkloadCalculation"
       asp-action="Index"
       asp-route-startYear="@Model.SelectedYearStart"
       class="btn @(Model.ActiveTab == "workload" ? "btn-primary" : "btn-outline-primary")">
        Дисциплины
    </a>

    <a asp-controller="PracticeCalculation"
       asp-action="Index"
       asp-route-startYear="@Model.SelectedYearStart"
       class="btn @(Model.ActiveTab == "practice" ? "btn-primary" : "btn-outline-primary")">
        Практики
    </a>

    <a asp-controller="GiaCalculation"
       asp-action="Index"
       asp-route-startYear="@Model.SelectedYearStart"
       class="btn @(Model.ActiveTab == "gia" ? "btn-primary" : "btn-outline-primary")">
        ГИА
    </a>
</div>