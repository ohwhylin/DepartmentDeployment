@model List<DepartmentLoadApp.Models.Gia.GiaWorkloadRow>

@{
    var indexOffset = (int?)ViewData["IndexOffset"] ?? 0;
}

@if (Model.Count == 0)
{
    <div class="alert alert-light border">Нет строк для отображения.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Семестр</th>
                    <th>Форма обучения</th>
                    <th>Код направления</th>
                    <th>Вид работы</th>
                    <th>Курс</th>
                    <th>Групп</th>
                    <th>Студентов</th>
                    <th>Часы</th>
                    <th>Итого</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var index = indexOffset + i;

                    <tr>
                        <td>
                            @Model[i].SemesterName
                            <input type="hidden" name="Rows[@index].Id" value="@Model[i].Id" />
                            <input type="hidden" name="Rows[@index].PlanYear" value="@Model[i].PlanYear" />
                            <input type="hidden" name="Rows[@index].AcademicPlanId" value="@Model[i].AcademicPlanId" />
                            <input type="hidden" name="Rows[@index].AcademicPlanRecordId" value="@Model[i].AcademicPlanRecordId" />
                            <input type="hidden" name="Rows[@index].GiaSection" value="@Model[i].GiaSection" />
                            <input type="hidden" name="Rows[@index].WorkName" value="@Model[i].WorkName" />
                            <input type="hidden" name="Rows[@index].DirectionCode" value="@Model[i].DirectionCode" />
                            <input type="hidden" name="Rows[@index].DirectionName" value="@Model[i].DirectionName" />
                            <input type="hidden" name="Rows[@index].Course" value="@Model[i].Course" />
                            <input type="hidden" name="Rows[@index].SemesterName" value="@Model[i].SemesterName" />
                            <input type="hidden" name="Rows[@index].EducationForm" value="@Model[i].EducationForm" />
                            <input type="hidden" name="Rows[@index].StudentsCount" value="@Model[i].StudentsCount" />
                            <input type="hidden" name="Rows[@index].GroupCount" value="@Model[i].GroupCount" />
                            <input type="hidden" name="Rows[@index].TotalHours" value="@Model[i].TotalHours.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                        </td>
                        <td>@Model[i].EducationForm</td>
                        <td>@Model[i].DirectionCode</td>
                        <td>@Model[i].WorkName</td>
                        <td>@Model[i].Course</td>
                        <td>@Model[i].GroupCount</td>
                        <td>@Model[i].StudentsCount</td>
                        <td>
                            @if (Model[i].WorkName == "Консультация к госэкзамену")
                            {
                                <input type="number"
                                       step="1"
                                       min="0"
                                       name="Rows[@index].ManualHours"
                                       value="@Math.Round(Model[i].ManualHours, 0, MidpointRounding.AwayFromZero)"
                                       class="form-control form-control-sm" />
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                                <input type="hidden"
                                       name="Rows[@index].ManualHours"
                                       value="@Model[i].ManualHours.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                            }
                        </td>
                        <td>@Math.Round(Model[i].TotalHours, 0, MidpointRounding.AwayFromZero)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}